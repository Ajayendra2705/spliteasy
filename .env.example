# PostgreSQL connection string (Supabase / Render / Railway / local)
# Local example: postgresql://postgres:postgres@localhost:5432/spliteasy?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to sign JWT session tokens. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-secret"
