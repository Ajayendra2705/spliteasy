// Prisma schema for SplitEasy - a simplified Splitwise-inspired app.
// Relational database: PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  memberships     GroupMember[]
  expensesPaid    Expense[]      @relation("ExpensePaidBy")
  expensesCreated Expense[]      @relation("ExpenseCreatedBy")
  splits          ExpenseSplit[]
  messages        Message[]
  paymentsFrom    Settlement[]   @relation("SettlementFrom")
  paymentsTo      Settlement[]   @relation("SettlementTo")
  groupsCreated   Group[]        @relation("GroupCreatedBy")
  invitationsSent Invitation[]   @relation("InvitationInvitedBy")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  createdById String

  createdBy   User         @relation("GroupCreatedBy", fields: [createdById], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  invitations Invitation[]
}

// A pending invitation to join a group, addressed to an email that may not yet
// have an account. When that email signs up, the invitation is auto-accepted and
// a membership is created.
model Invitation {
  id          String   @id @default(cuid())
  groupId     String
  email       String
  invitedById String
  status      String   @default("pending") // "pending" | "accepted"
  createdAt   DateTime @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("InvitationInvitedBy", fields: [invitedById], references: [id])

  @@unique([groupId, email])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("member") // "admin" | "member"
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// Split strategy used when creating an expense.
enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARE
}

model Expense {
  id          String    @id @default(cuid())
  groupId     String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  splitType   SplitType
  paidById    String
  createdById String
  createdAt   DateTime  @default(now())

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy    User           @relation("ExpensePaidBy", fields: [paidById], references: [id])
  createdBy User           @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  splits    ExpenseSplit[]
  messages  Message[]
}

// One row per participant in an expense: the amount that user owes for it.
model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal @db.Decimal(12, 2) // amount this user owes
  // raw input kept for editing / auditing: percentage or share weight
  weight    Decimal? @db.Decimal(12, 4)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

// Real-time chat messages attached to an expense.
model Message {
  id        String   @id @default(cuid())
  expenseId String
  userId    String
  body      String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A recorded payment that settles debt from one member to another.
model Settlement {
  id         String   @id @default(cuid())
  groupId    String
  fromUserId String
  toUserId   String
  amount     Decimal  @db.Decimal(12, 2)
  note       String?
  createdAt  DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id])
}
